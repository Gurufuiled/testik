# Server
PORT=4000
WS_PORT=4001
SIGNALING_PORT=4002

# Database (PostgreSQL)
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/messenger"

# JWT
JWT_SECRET="your-secret-key-change-in-production"

# Loginus OAuth API (https://loginus.startapus.com)
# client_secret хранится ТОЛЬКО на backend (см. .cursor/rules/auth.mdc)
LOGINUS_BASE_URL=https://loginus.startapus.com
LOGINUS_CLIENT_ID=36bd25a329898885fd4b60c9f7b4f475
LOGINUS_CLIENT_SECRET=d41b1d8e862402d35f890d68b243d3de6d5fcff84d908f44cd5e6ff5c834d1ff
# Redirect URI — HTTP, должен совпадать с настройкой в Loginus.
# Loginus редиректит сюда, backend перенаправляет в messenger://
# Пример: http://192.168.1.85:4000/api/auth/callback
LOGINUS_REDIRECT_URI=http://192.168.1.85:4000/api/auth/callback
# Post Logout Redirect URI (for SLO). Loginus redirects here after end_session.
LOGINUS_REDIRECT_URI_LOGOUT=http://192.168.1.85:4000/api/auth/logout-done
